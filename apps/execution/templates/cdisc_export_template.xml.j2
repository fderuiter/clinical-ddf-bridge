<?xml version="1.0" encoding="UTF-8"?>
<ODM xmlns="http://www.cdisc.org/ns/odm/v1.3"
     ODMVersion="1.3"
     FileType="Transactional"
     FileOID="Export.{{ study_id }}"
     CreationDateTime="{{ creation_datetime }}">
  <ClinicalData StudyOID="Study.{{ study_id }}" MetaDataVersionOID="MDV.1">
    {% for subject_key, subject in subjects.items() %}
    <SubjectData SubjectKey="{{ subject_key }}">
      {% for visit_name, observations in subject.visits.items() %}
      <StudyEventData StudyEventOID="Event.{{ visit_name }}">
        {% for obs in observations %}
        <FormData FormOID="Form.{{ obs.domain }}">
          <ItemGroupData ItemGroupOID="Group.{{ obs.domain }}" ItemGroupRepeatKey="1">
            <ItemData ItemOID="{{ obs.test_code }}" Value="{% if obs.value is not none %}{{ obs.value }}{% else %}{{ obs.value_string }}{% endif %}"/>
          </ItemGroupData>
        </FormData>
        {% endfor %}
      </StudyEventData>
      {% endfor %}
    </SubjectData>
    {% endfor %}
  </ClinicalData>
</ODM>
